<Window x:Class="MochiV2.UI.SpeechBubble.SpeechBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpeechBubble"
        Width="300" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False">
    <Border Background="#DD2D2D2D"
            CornerRadius="12"
            Padding="12,8"
            Margin="0,0,0,12"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom">
        <Border.RenderTransform>
            <ScaleTransform x:Name="BubbleScale" CenterX="150" CenterY="70" ScaleX="0" ScaleY="0"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <TextBlock x:Name="BubbleText"
                   Foreground="White"
                   FontSize="14"
                   FontFamily="Segoe UI"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"/>
    </Border>
</Window>