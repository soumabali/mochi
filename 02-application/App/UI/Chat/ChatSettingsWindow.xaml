<Window x:Class="MochiV2.UI.Chat.ChatSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mochi Chat Settings"
        Width="450" Height="380"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FF1E1E2E">
    <StackPanel Margin="20">
        <TextBlock Text="💬 Chat / LLM Settings"
                   Foreground="#FF89B4FA"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="API URL" Foreground="#FFA6ADC8" FontSize="13" Margin="0,0,0,4"/>
        <TextBox x:Name="ApiUrlBox" Background="#FF313244" Foreground="#FFCDD6F4"
                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,12"/>
        <TextBlock Text="Examples: https://api.openai.com/v1 | http://localhost:11434/v1 | https://api.groq.com/openai/v1"
                   Foreground="#FF6C7086" FontSize="11" Margin="0,0,0,12"/>

        <TextBlock Text="API Key (leave empty for local Ollama)" Foreground="#FFA6ADC8" FontSize="13" Margin="0,0,0,4"/>
        <TextBox x:Name="ApiKeyBox" Background="#FF313244" Foreground="#FFCDD6F4"
                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,12"/>

        <TextBlock Text="Model" Foreground="#FFA6ADC8" FontSize="13" Margin="0,0,0,4"/>
        <TextBox x:Name="ModelBox" Background="#FF313244" Foreground="#FFCDD6F4"
                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,12"/>
        <TextBlock Text="Examples: gpt-4o-mini | llama3.2 | qwen2.5 | gemma2"
                   Foreground="#FF6C7086" FontSize="11" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Save" Background="#FFA6E3A1" Foreground="#FF1E1E2E"
                    BorderThickness="0" Padding="24,8" FontSize="14"
                    Click="OnSaveClick" Margin="0,0,12,0"/>
            <Button Content="Cancel" Background="#FF313244" Foreground="#FFCDD6F4"
                    BorderThickness="0" Padding="24,8" FontSize="14"
                    Click="OnCancelClick"/>
        </StackPanel>
    </StackPanel>
</Window>