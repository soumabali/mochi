<Window x:Class="MochiV2.UI.Stats.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mochi Stats"
        Width="320" Height="420"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FF1E1E2E">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <!-- Header -->
            <TextBlock Text="🐾 Mochi Stats"
                       Foreground="#FF89B4FA"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Level & XP -->
            <Border Background="#FF313244" CornerRadius="8" Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Lv. " Foreground="#FFCDD6F4" FontSize="18"/>
                        <TextBlock x:Name="LevelText" Text="1" Foreground="#FFFAB387" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <ProgressBar x:Name="XpBar" Height="8" Minimum="0" Maximum="100" Value="0"
                                 Foreground="#FFFAB387" Background="#FF45475A"/>
                </StackPanel>
            </Border>

            <!-- Needs -->
            <Border Background="#FF313244" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Needs" Foreground="#FF89B4FA" FontSize="14" FontWeight="Bold"/>
                    <StackPanel>
                        <TextBlock Text="🍽️ Food" Foreground="#FFA6E3A1" FontSize="12"/>
                        <ProgressBar x:Name="FoodBar" Height="10" Minimum="0" Maximum="100" Value="80"
                                     Foreground="#FFA6E3A1" Background="#FF45475A"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="⚡ Energy" Foreground="#FF89DCEB" FontSize="12"/>
                        <ProgressBar x:Name="EnergyBar" Height="10" Minimum="0" Maximum="100" Value="80"
                                     Foreground="#FF89DCEB" Background="#FF45475A"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="💖 Happiness" Foreground="#FFF5C2E7" FontSize="12"/>
                        <ProgressBar x:Name="HappinessBar" Height="10" Minimum="0" Maximum="100" Value="80"
                                     Foreground="#FFF5C2E7" Background="#FF45475A"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mood -->
            <Border Background="#FF313244" CornerRadius="8" Padding="12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Mood:" Foreground="#FFCDD6F4" FontSize="14"/>
                    <TextBlock x:Name="MoodText" Text="Content 😊" Foreground="#FFF9E2AF" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Pomodoro -->
            <Border Background="#FF313244" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="🍅 Pomodoro" Foreground="#FF89B4FA" FontSize="14" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="State:" Foreground="#FFCDD6F4" FontSize="12"/>
                        <TextBlock x:Name="PomodoroStateText" Text="Idle" Foreground="#FFFAB387" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Remaining:" Foreground="#FFCDD6F4" FontSize="12"/>
                        <TextBlock x:Name="PomodoroTimeText" Text="--:--" Foreground="#FFA6E3A1" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Weather -->
            <Border Background="#FF313244" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="🌤️ Weather" Foreground="#FF89B4FA" FontSize="14" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="WeatherTempText" Text="--°C" Foreground="#FF89DCEB" FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="WeatherDescText" Text="--" Foreground="#FFCDD6F4" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>