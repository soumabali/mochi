<Window x:Class="MochiV2.UI.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mochi Settings"
        Width="480" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True"
        Background="{StaticResource BgBrush}"
        FocusManager.FocusedElement="{Binding ElementName=StartWithWindowsToggle}"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Design tokens (DESIGN.md §1) -->
        <Color x:Key="PrimaryColor">#E8A0BF</Color>
        <Color x:Key="PrimaryHoverColor">#D88BA5</Color>
        <Color x:Key="AccentColor">#FFB4A2</Color>
        <Color x:Key="BgColor">#FFF8F0</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="TextColor">#5D4037</Color>
        <Color x:Key="TextMutedColor">#8D6E63</Color>
        <Color x:Key="DangerColor">#EF5350</Color>
        <Color x:Key="SuccessColor">#81C784</Color>
        <Color x:Key="SleepColor">#9575CD</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

        <!-- Section heading -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Body label -->
        <Style x:Key="BodyLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Muted hint -->
        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Card panel: surface bg, radius-md 12, md padding -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- Sakura-pink focus ring (DESIGN accessibility floor) -->
        <Style TargetType="Control">
            <Setter Property="FocusVisualStyle">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border CornerRadius="6"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="2"
                                Margin="-2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider styled with sakura track -->
        <Style x:Key="MochiSlider" TargetType="Slider">
            <Setter Property="TickPlacement" Value="None" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" CornerRadius="3"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource TextMutedBrush}"
                                    Opacity="0.25" />
                            <Track Name="PART_Track"
                                   Height="20"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3"
                                                        Background="{StaticResource PrimaryBrush}" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="{StaticResource PrimaryBrush}"
                                                         Stroke="{StaticResource SurfaceBrush}"
                                                         StrokeThickness="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle (CheckBox styled as pill switch) -->
        <Style x:Key="MochiToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track"
                                    Width="44" Height="24"
                                    CornerRadius="12"
                                    Background="{StaticResource TextMutedBrush}"
                                    Opacity="0.35" />
                            <Border x:Name="Knob"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"
                                    Background="{StaticResource SurfaceBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Track" Property="Opacity" Value="1" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment"
                                        Value="Right" />
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (Save) button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (Cancel) button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource TextMutedBrush}"
                                BorderThickness="1.5"
                                CornerRadius="20"
                                Opacity="0.6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer padding: space-lg 24px -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🐱 Mochi Settings"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Tweak your companion just the way you like."
                       Style="{StaticResource MutedLabel}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Scrollable sections -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,4,0">
            <StackPanel>

                <!-- 1. General -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start Mochi with Windows"
                                           Style="{StaticResource BodyLabel}" />
                                <TextBlock Text="Launch automatically on boot."
                                           Style="{StaticResource MutedLabel}" />
                            </StackPanel>
                            <CheckBox x:Name="StartWithWindowsToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MochiToggle}"
                                      TabIndex="0"
                                      IsChecked="{Binding StartWithWindows}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Personality -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Personality" Style="{StaticResource SectionTitle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Calm 😌"
                                       Style="{StaticResource BodyLabel}" />
                            <TextBlock Grid.Column="2" Text="😈 Chaotic"
                                       Style="{StaticResource BodyLabel}" />
                        </Grid>
                        <Slider x:Name="PersonalitySlider"
                                Style="{StaticResource MochiSlider}"
                                TabIndex="1"
                                Minimum="0" Maximum="1"
                                TickFrequency="0.05"
                                Value="{Binding Personality}" />
                        <TextBlock x:Name="PersonalityValue"
                                   Style="{StaticResource MutedLabel}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <!-- 3. Volume -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Volume" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Master volume 🔊"
                                   Style="{StaticResource BodyLabel}" />
                        <Slider x:Name="VolumeSlider"
                                Style="{StaticResource MochiSlider}"
                                TabIndex="2"
                                Minimum="0" Maximum="1"
                                TickFrequency="0.05"
                                Value="{Binding MasterVolume}" />
                        <TextBlock x:Name="VolumeValue"
                                   Style="{StaticResource MutedLabel}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <!-- 4. Behavior -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Behavior" Style="{StaticResource SectionTitle}" />

                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Enable sound 🔊"
                                           Style="{StaticResource BodyLabel}" />
                                <TextBlock Text="Meows, purrs, and cute SFX."
                                           Style="{StaticResource MutedLabel}" />
                            </StackPanel>
                            <CheckBox x:Name="EnableSoundToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MochiToggle}"
                                      TabIndex="3"
                                      IsChecked="{Binding EnableSound}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Typing awareness ⌨️"
                                           Style="{StaticResource BodyLabel}" />
                                <TextBlock Text="Mochi reacts to your typing rhythm."
                                           Style="{StaticResource MutedLabel}" />
                            </StackPanel>
                            <CheckBox x:Name="EnableTypingAwarenessToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MochiToggle}"
                                      TabIndex="4"
                                      IsChecked="{Binding EnableTypingAwareness}" />
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Night mode 🌙"
                                           Style="{StaticResource BodyLabel}" />
                                <TextBlock Text="Dim &amp; quiet Mochi at night."
                                           Style="{StaticResource MutedLabel}" />
                            </StackPanel>
                            <CheckBox x:Name="EnableNightModeToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MochiToggle}"
                                      TabIndex="5"
                                      IsChecked="{Binding EnableNightMode}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 5. Scale -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Scale" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Sprite size 🐾"
                                   Style="{StaticResource BodyLabel}" />
                        <Slider x:Name="ScaleSlider"
                                Style="{StaticResource MochiSlider}"
                                TabIndex="6"
                                Minimum="0.5" Maximum="2.0"
                                TickFrequency="0.05"
                                Value="{Binding SpriteScale}" />
                        <TextBlock x:Name="ScaleValue"
                                   Style="{StaticResource MutedLabel}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <!-- 6. Language -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Language" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Interface language 🌐"
                                   Style="{StaticResource BodyLabel}" />
                        <ComboBox x:Name="LanguageComboBox"
                                  TabIndex="7"
                                  Margin="0,6,0,0"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{Binding Language}"
                                  Background="{StaticResource SurfaceBrush}"
                                  Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="English for now — more soon!"
                                   Style="{StaticResource MutedLabel}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action bar -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    TabIndex="8"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    TabIndex="9"
                    IsDefault="True"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>